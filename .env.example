# Autonomous Research Pipeline - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED - Must be set before starting the server
# =============================================================================

# PostgreSQL async connection string (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/research

# PostgreSQL sync connection string (psycopg driver for alembic/checkpointer)
# Format: postgresql+psycopg://user:password@host:port/database
DATABASE_URL_SYNC=postgresql+psycopg://user:password@localhost:5432/research

# Your OpenAI-compatible API key (OpenRouter, OpenAI, DeepSeek, etc.)
LLM_API_KEY=your-api-key-here

# Serper API key for web search (get one at https://serper.dev)
SERPER_API_KEY=your-serper-api-key-here

# =============================================================================
# OPTIONAL - LLM Configuration (defaults shown)
# =============================================================================

# OpenAI-compatible API base URL
# OpenRouter: https://openrouter.ai/api/v1
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
LLM_BASE_URL=https://openrouter.ai/api/v1

# Model name to use
# OpenRouter free: nvidia/nemotron-3-ultra-550b-a55b:free
# OpenAI: gpt-4o-mini, gpt-4o
# DeepSeek: deepseek-chat
LLM_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Sampling temperature (0.0-2.0)
LLM_TEMPERATURE=0.2

# Max output tokens per request
LLM_MAX_TOKENS=4096

# Request timeout in seconds
LLM_TIMEOUT_SECONDS=60.0

# =============================================================================
# OPTIONAL - Serper Search Configuration (defaults shown)
# =============================================================================

# Serper API base URL
SERPER_BASE_URL=https://google.serper.dev

# Serper request timeout in seconds
SERPER_TIMEOUT_SECONDS=20.0

# =============================================================================
# OPTIONAL - Database Pool Configuration (defaults shown)
# =============================================================================

# Connection pool size
DATABASE_POOL_SIZE=10

# Max overflow connections
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# OPTIONAL - Research Pipeline Limits (defaults shown)
# =============================================================================

# Hard cap on number of research tasks the planner can create
MAX_RESEARCH_TASKS=5

# Hard cap on sources per research task
MAX_SOURCES_PER_TASK=3

# Minimum relevance score for fact-checker to keep a source (0.0-1.0)
MIN_SOURCE_RELEVANCE=0.4

# =============================================================================
# OPTIONAL - Application Settings (defaults shown)
# =============================================================================

# Environment: development, production, test
APP_ENV=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug mode (verbose logging, SQL echo)
DEBUG=false

# Server host
HOST=0.0.0.0

# Server port
PORT=8000

# Worker count (for production with gunicorn)
WORKERS=1